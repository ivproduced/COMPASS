# ============================================================
# COMPASS Backend — Environment Variables
# Copy to .env and fill in your values.
# Never commit .env to source control.
# ============================================================

# ---- Google Cloud Fundamentals ----
GOOGLE_CLOUD_PROJECT=compass-fedramp
GOOGLE_CLOUD_LOCATION=us-central1

# ---- Gemini Live API ----
GEMINI_MODEL=gemini-2.5-pro
GEMINI_VOICE=Kore

# ---- Firestore ----
FIRESTORE_DATABASE=compass

# ---- Google Cloud Storage ----
GCS_BUCKET_OSCAL=compass-fedramp-oscal
GCS_BUCKET_DIAGRAMS=compass-fedramp-diagrams

# ---- Vertex AI Vector Search ----
VECTOR_SEARCH_INDEX_ID=
VECTOR_SEARCH_INDEX_ENDPOINT_ID=
EMBEDDING_MODEL=text-embedding-005
EMBEDDING_DIMENSIONS=768

# ---- Auth (Firebase Admin SDK) ----
FIREBASE_PROJECT_ID=compass-fedramp
# Path to service account JSON (local dev only — use Workload Identity on GCP)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ---- App Server ----
HOST=0.0.0.0
PORT=8080
ENV=development

# ---- CORS ----
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- OSCAL Config ----
OSCAL_MIN_COVERAGE_FOR_SSP=0.80
